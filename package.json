{
  "name": "codemirror-helix",
  "version": "0.4.3",
  "type": "module",
  "license": "MPL-2.0",
  "author": "Roberto Vidal",
  "description": "Helix bindings for CodeMirror",
  "keywords": [
    "code",
    "editor",
    "helix",
    "codemirror"
  ],
  "scripts": {
    "demo": "cd demo && vite",
    "build": "./etc/build.sh",
    "build:test": "SKIP_TS=1 npm run build",
    "test": "wdio run ./wdio.conf.ts"
  },
  "files": [
    "dist/*"
  ],
  "types": "./dist/lib.d.ts",
  "main": "./dist/lib.js",
  "exports": {
    "development": "./dist/lib.development.js",
    "default": "./dist/lib.js"
  },
  "sideEffects": false,
  "devDependencies": {
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.9",
    "@codemirror/lang-javascript": "^6.0.0",
    "@codemirror/lang-json": "^6.0.1",
    "@codemirror/lang-markdown": "^6.3.2",
    "@codemirror/lang-yaml": "^6.1.2",
    "@lezer/common": "^1.2.1",
    "@shoelace-style/shoelace": "^2.16.0",
    "@wdio/cli": "^9.7.2",
    "@wdio/local-runner": "^9.7.2",
    "@wdio/mocha-framework": "^9.19.2",
    "@wdio/spec-reporter": "^8.36.1",
    "esbuild": "^0.25.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.2.2",
    "vite": "^7.1.4",
    "webdriverio": "^9.7.2"
  },
  "peerDependencies": {
    "@codemirror/commands": "^6.0.0",
    "@codemirror/language": "^6.0.0",
    "@codemirror/search": "^6.0.0",
    "@codemirror/state": "^6.0.0",
    "@codemirror/view": "^6.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://gitlab.com/_rvidal/codemirror-helix.git"
  }
}
