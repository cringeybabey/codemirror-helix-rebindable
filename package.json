{
  "name": "codemirror-helix",
  "version": "0.2.0",
  "type": "module",
  "license": "MPL-2.0",
  "author": "Roberto Vidal",
  "description": "Helix bindings for CodeMirror",
  "keywords": [
    "code",
    "editor",
    "helix",
    "codemirror"
  ],
  "scripts": {
    "demo": "cd demo && vite",
    "build": "rm -rf dist/ && ./etc/build.sh",
    "test": "wdio run ./wdio.conf.ts"
  },
  "files": [
    "dist/*"
  ],
  "types": "./dist/lib.d.ts",
